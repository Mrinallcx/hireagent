# ---- Models ----
# Kimi (Moonshot) powers the web-search tool. Required for RESEARCH_MODE=eve|legacy.
KIMI_API_KEY=sk-your-kimi-key

# Groq powers orchestration + subagents via the AI SDK. Required for RESEARCH_MODE=eve.
GROQ_API_KEY=gsk_your-groq-key

# ---- Engine ----
# eve = real Eve agent (default) | mock = deterministic fixtures | legacy = old researcher.ts
RESEARCH_MODE=eve

# Origin where the Eve runtime is reachable. Under withEve this is the Next origin.
EVE_BASE_URL=http://127.0.0.1:3000

# Origin the Eve sync hook posts back to (the Next app).
WEB_BASE_URL=http://127.0.0.1:3000

# Shared secret for the internal /api/internal/agent-events webhook.
# MUST match between the Next app and the Eve runtime. Set a strong value in prod.
INTERNAL_WEBHOOK_SECRET=change-me-in-production

# ---- Public guards (optional overrides) ----
# MAX_RUNS_PER_IP_PER_DAY=3
# MAX_KING_PER_IP_PER_DAY=1
# MAX_CONCURRENT_RUNS=2
# OBJECTIVE_MAX=2000

# ---- Mock mode (optional) ----
# MOCK_STEP_MS=400
